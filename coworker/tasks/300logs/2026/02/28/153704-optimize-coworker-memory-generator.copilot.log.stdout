# Function to extract copilot output
extract_copilot_output() {
    local copilot_log="$1"
    if [ -f "$copilot_log" ]; then
        # Head 10 lines
        head -n 10 "$copilot_log"
        echo ""
        echo "... [Intermediate logs skipped] ..."
        echo ""

        # Find line number of the LAST tool execution
