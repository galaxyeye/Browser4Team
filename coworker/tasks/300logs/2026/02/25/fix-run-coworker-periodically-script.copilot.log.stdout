```powershell
$ScriptName = "coworker.ps1"
$escapedName = [regex]::Escape($ScriptName)
$pattern = "(?i)(^|[\s""'/\\\\])$escapedName($|[\s""'])"

$inputs = @(
    "D:\path\coworker.ps1",
    ".\coworker.ps1",
    "coworker.ps1",
    "run_coworker_periodically.ps1",
    "debug_run_coworker_periodically.ps1",
    "my-coworker.ps1",
    "coworker.ps1.bak",
    "coworker.ps11",
    '"D:\path\coworker.ps1"',
    "pwsh -File coworker.ps1",
    "pwsh -File .\coworker\scripts\run_coworker_periodically.ps1"
)

Write-Host "Pattern: $pattern"
foreach ($i in $inputs) {
    $match = $i -match $pattern
    Write-Host "$($match): '$i'"
}
```
